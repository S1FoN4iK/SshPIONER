# --- Telegram ---
# Токен от @BotFather
BOT_TOKEN=

# Чат, куда поллер постит новые ролики (и где удобно общаться с ботом).
# Для группы это ОТРИЦАТЕЛЬНЫЙ id.
# Пусто -> слежение за профилями выключено.
TARGET_CHAT_ID=

# Необязательный белый список chat id, которым можно пользоваться ботом.
# Пусто -> можно всем.
ALLOWED_CHAT_IDS=

# --- Слежение за профилями (только TikTok) ---
# Через запятую: username, @handle или полная ссылка на профиль.
TIKTOK_PROFILES=

# Интервал проверки профилей, секунды (не ставьте слишком мало — рейт-лимиты)
POLL_INTERVAL_SECONDS=300

# --- Загрузка ---
# Порядок провайдеров для TikTok: tikwm (без вотермарки, HD), ytdlp (фолбэк).
# Instagram и YouTube всегда идут через yt-dlp.
PROVIDER_ORDER=tikwm,ytdlp

# Эндпоинт tikwm
TIKWM_API_BASE=https://www.tikwm.com

# Лимит Bot API на загрузку файла
MAX_FILE_SIZE_MB=49

# Потолок разрешения для YouTube (чтобы файл влезал в лимит и не требовался ffmpeg).
YOUTUBE_MAX_HEIGHT=720

# Добавлять подпись "@автор + ссылка" к видео
SEND_CAPTION=true

# --- Сеть ---
# Прокси для ВСЕХ исходящих запросов (tikwm + yt-dlp). Пусто -> напрямую.
# http(s) работает из коробки; для socks нужен extra: uv add "httpx[socks]".
# Примеры: http://user:pass@host:port   socks5://user:pass@host:1080
PROXY_URL=

# --- Авторизация (необязательно; в основном для Instagram / возрастных видео) ---
# Путь к файлу cookies.txt (формат Netscape), выгруженному из залогиненного браузера.
COOKIES_FILE=

# Либо брать cookies прямо из установленного браузера: chrome, firefox, edge, ...
COOKIES_FROM_BROWSER=

# --- Хранилище ---
STATE_FILE=state.db
